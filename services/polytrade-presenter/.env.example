# ---- Polytrade -> AIRI presenter bridge ----

# Polytrade's live snapshot feed (REQUIRED). The same JSON the built-in
# /live presenter polls. Point at your deployed Polytrade instance.
POLYTRADE_SNAPSHOT_URL=https://your-polytrade.up.railway.app/snapshot

# AIRI server WebSocket endpoint the bridge connects to as a module.
AIRI_SERVER_URL=ws://localhost:6121/ws

# Auth token — only needed if your AIRI server enforces authentication.
# AIRI_SERVER_TOKEN=

# Detection cadence (defaults mirror Polytrade's live.html).
POLL_INTERVAL_MS=3000
SUMMARY_INTERVAL_MS=48000
# Suppress the periodic summary if a line was sent within this window.
SUMMARY_QUIET_MS=20000

# Conversation/memory lane id so AIRI keeps one coherent session for the feed.
SESSION_ID=polytrade-live

# Optional source prefix on the message the brain receives (kept empty by
# default; prefer baking framing into the stage-web persona).
# MESSAGE_PREFIX=(Polytrade live feed)

# Greeting.
PRESENTER_NAME=Aria
GREET_ON_CONNECT=true
