# ---- Polytrade -> AIRI presenter bridge ----

# Polytrade's live snapshot feed (REQUIRED). The same JSON the built-in
# /live presenter polls. Point at your deployed Polytrade instance.
POLYTRADE_SNAPSHOT_URL=https://your-polytrade.up.railway.app/snapshot

# AIRI server WebSocket endpoint the bridge connects to as a module.
AIRI_SERVER_URL=ws://localhost:6121/ws

# Auth token — only needed if your AIRI server enforces authentication.
# AIRI_SERVER_TOKEN=

# Detection cadence (defaults mirror Polytrade's live.html).
POLL_INTERVAL_MS=3000
SUMMARY_INTERVAL_MS=48000
# Suppress the periodic summary if a line was sent within this window.
SUMMARY_QUIET_MS=20000

# "Market read" STAR opines on, and its quiet-gate.
OPINION_INTERVAL_MS=150000
OPINION_QUIET_MS=25000

# Recurring "mission briefing" recap from session memory (streaks, records,
# hot pair). Hourly by default.
BRIEFING_INTERVAL_MS=3600000

# In-character "lore" fills genuine dead air. The bridge checks every
# LORE_INTERVAL_MS but only speaks once it's been silent for LORE_QUIET_MS.
LORE_INTERVAL_MS=60000
LORE_QUIET_MS=120000

# Conversation/memory lane id so AIRI keeps one coherent session for the feed.
SESSION_ID=polytrade-live

# Optional source prefix on the message the brain receives (kept empty by
# default; prefer baking framing into the stage-web persona).
# MESSAGE_PREFIX=(Polytrade live feed)

# Greeting.
PRESENTER_NAME=Aria
GREET_ON_CONNECT=true

# Speech pacing. Lines are spoken one at a time (a new line interrupts the
# current one), so the bridge waits each line's estimated duration + this gap
# before sending the next. A multi-event poll past MAX_NARRATED_PER_TICK is
# collapsed into one summary line; the backlog is capped at MAX_QUEUED_LINES so
# a fast burst (e.g. canary mode) stays close to live instead of lagging.
SPEECH_GAP_MS=800
MAX_NARRATED_PER_TICK=2
MAX_QUEUED_LINES=6
